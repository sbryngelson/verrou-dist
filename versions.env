# Pinned upstream versions — the single source of truth for this repo.
# Verrou DRIVES the pairing: VALGRIND_VERSION is the Valgrind release that the
# pinned Verrou commit's patch (valgrind.<ver>.diff) targets. The watch workflow
# resolves it automatically (resolve_versions.py) and opens a bump PR.
VALGRIND_VERSION=3.26.0
VERROU_COMMIT=a58d434

# Optional supply-chain pin: if set, build.sh verifies the Valgrind tarball's
# SHA-256. Leave empty to skip. (Bump PRs do NOT auto-update this — set it by hand
# when bumping VALGRIND_VERSION.)
VALGRIND_SHA256=
